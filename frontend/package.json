{
  "name": "wavely",
  "version": "1.1.5",
  "description": "Cross-platform push-to-talk speech-to-text using Deepgram — Wavely",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish always",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -m .",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.8",
    "@deepgram/sdk": "^5.2.0",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "emoji-picker-react": "^4.19.1",
    "ffmpeg-static": "^5.3.0",
    "flag-icons": "^7.5.0",
    "framer-motion": "^12.39.0",
    "groq-sdk": "^1.2.0",
    "i18next": "^26.2.0",
    "lucide-react": "^1.16.0",
    "react-i18next": "^17.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uiohook-napi": "^1.5.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.22.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^4.1.6"
  },
  "repository": "https://github.com/theyluvEnething/speech-to-text",
  "build": {
    "appId": "com.wavely.app",
    "productName": "Wavely",
    "copyright": "Copyright (c) 2026 Enething",
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "theyluvEnething",
        "repo": "speech-to-text"
      }
    ],
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "wavely-installer.${ext}"
    }
  }
}
