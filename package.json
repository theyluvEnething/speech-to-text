{
  "name": "whisper-push-to-talk",
  "version": "2.0.0",
  "description": "Cross-platform push-to-talk speech-to-text using Deepgram",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "tui": "tsx src/tui/index.ts",
    "rebuild": "electron-rebuild -f -m .",
    "postinstall": "electron-rebuild -f -m . || true"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.2.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "ink": "^5.2.1",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.22.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "com.whisper-push-to-talk.app",
    "productName": "Whisper PTT",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
